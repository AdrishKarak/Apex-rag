{
  "name": "github-rag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run next build",
    "check": "bun run next lint && bun run tsc --noEmit",
    "db:generate": "bun run prisma migrate dev",
    "db:migrate": "bun run prisma migrate deploy",
    "db:push": "bun run prisma db push",
    "db:studio": "bun run prisma studio",
    "dev": "bun run next dev --turbo",
    "format:check": "bun run prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "bun run prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "bun run prisma generate",
    "lint": "bun run next lint",
    "lint:fix": "bun run next lint --fix",
    "preview": "bun run next build && bun run next start",
    "start": "bun run next start",
    "typecheck": "bun run tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/client": "^7.9.0",
    "@shadcn/react": "^0.2.1",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.25.0",
    "next": "^15.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.14.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^7.9.0",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  }
}